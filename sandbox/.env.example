# 复制为 sandbox/.env 并填入你的真实 LLM。.env 不会进 git（见 .gitignore）。
# OpenClaw 用这里的真实模型运行——满足科研用途。

# ---- 真实 LLM ----
LLM_API_KEY=sk-REPLACE_ME                 # 你的真实 API key（唯一进入容器的凭据）
LLM_MODEL=gpt-4o-mini                      # 模型 id
LLM_BASE_URL=https://api.openai.com/v1     # OpenAI 兼容端点（Anthropic/OpenRouter/自有皆可）
LLM_API=openai-responses                   # 适配器: openai-responses | openai-completions | anthropic-messages

# ---- 出网允许列表（“代码保险”的核心）----
# OpenClaw 只能访问下面这个域名，其它一切（含云元数据/任意外泄）全部拒绝。
# 换 provider 时改成对应域名，例如 api.anthropic.com / openrouter.ai
EGRESS_ALLOW=api.openai.com
