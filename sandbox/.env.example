# Copy to sandbox/.env and fill in your real LLM. .env is gitignored.
# OpenClaw runs against this real model.

# ---- Real LLM (DeepSeek, OpenAI-compatible) ----
LLM_API_KEY=sk-REPLACE_ME                  # your real API key (the only secret in the container)
LLM_MODEL=deepseek-chat                     # model id
LLM_BASE_URL=https://api.deepseek.com/v1    # OpenAI-compatible endpoint
LLM_API=openai-completions                  # adapter: openai-completions | openai-responses | anthropic-messages

# ---- Egress allowlist (the core safety layer) ----
# OpenClaw may only reach this domain; everything else (cloud metadata, exfil) is denied.
# Change this when you change provider, e.g. api.openai.com / api.anthropic.com
EGRESS_ALLOW=api.deepseek.com
